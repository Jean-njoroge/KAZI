direction: right

# ============================================================
# PANEL 1: AGENT RUNTIME
# ============================================================
agent_runtime: Agent Runtime {
  style: {
    fill: "#f8f6f1"
    stroke: "#2d4a5e"
    stroke-width: 2
    border-radius: 8
    font-size: 20
    bold: true
  }

  tools: Abstracted Tools {
    style: {
      fill: "#e8f4f0"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 14
    }

    llm: LLM {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
      }
    }
    web_search: Web Search {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
      }
    }
    http: HTTP Client {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
      }
    }
    custom: Custom Tools {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
      }
    }
  }

  base_agent: BaseAgent {
    style: {
      fill: "#dceef5"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 14
      bold: true
    }
  }

  context: Job Context (_context) {
    style: {
      fill: "#e8f4f0"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 12
      italic: true
    }
  }

  retry: Retry / Backoff {
    style: {
      fill: "#e8f4f0"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 12
    }
  }

  validation: Schema Validation {
    style: {
      fill: "#e8f4f0"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 12
    }
  }

  tools -> base_agent: injected at runtime {
    style: {
      stroke: "#4a9e8e"
      stroke-dash: 3
      font-size: 10
    }
  }
  base_agent -> context: writes output {
    style: {
      stroke: "#4a9e8e"
      font-size: 10
    }
  }
  base_agent -> retry {
    style: {
      stroke: "#4a9e8e"
      font-size: 10
    }
  }
  base_agent -> validation {
    style: {
      stroke: "#4a9e8e"
      font-size: 10
    }
  }

  subtitle: |md
    Stateless · Async · Typed
    Runs inside each domain
  | {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 11
      font-color: "#6b7b8a"
    }
  }
}

# ============================================================
# PANEL 2: ORCHESTRATION LAYER
# ============================================================
orchestration: Orchestration Layer {
  style: {
    fill: "#f8f6f1"
    stroke: "#2d4a5e"
    stroke-width: 2
    border-radius: 8
    font-size: 20
    bold: true
  }

  pipeline: Pipeline DAG {
    style: {
      fill: "#dceef5"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 14
      bold: true
    }

    scout: Scout {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
      }
    }
    score: Score {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
      }
    }
    compile: Compile {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
      }
    }

    scout -> score -> compile {
      style: {
        stroke: "#4a9e8e"
        stroke-width: 2
      }
    }
  }

  fanout: Fan-Out / Parallel {
    style: {
      fill: "#e8f4f0"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 12
    }
  }

  traces: Semantic Traces {
    style: {
      fill: "#e8f4f0"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 12
      italic: true
    }
  }

  hitl: HITL Checkpoints {
    style: {
      fill: "#fff3cd"
      stroke: "#d4a017"
      border-radius: 4
      font-size: 12
    }
  }

  pipeline -> fanout: batch items {
    style: {
      stroke: "#4a9e8e"
      stroke-dash: 3
      font-size: 10
    }
  }
  pipeline -> traces: logs decisions {
    style: {
      stroke: "#4a9e8e"
      font-size: 10
    }
  }
  pipeline -> hitl: gates delivery {
    style: {
      stroke: "#d4a017"
      stroke-dash: 3
      font-size: 10
    }
  }

  subtitle: |md
    Platform orchestrates
    Domains don't talk to each other
  | {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 11
      font-color: "#6b7b8a"
    }
  }
}

# ============================================================
# PANEL 3: PLATFORM INFRASTRUCTURE
# ============================================================
infrastructure: Platform Infrastructure {
  style: {
    fill: "#f8f6f1"
    stroke: "#2d4a5e"
    stroke-width: 2
    border-radius: 8
    font-size: 20
    bold: true
  }

  ontology: Ontology Layer {
    style: {
      fill: "#dceef5"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 14
      bold: true
    }

    manifest: manifest.yaml {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 11
      }
    }
    scoring: scoring.yaml {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 11
      }
    }
    schemas: output schemas {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 11
      }
    }
  }

  context_graph: Context Graph {
    style: {
      fill: "#e8f4f0"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 14
    }

    jobs: Job History {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 11
      }
    }
    decay: Confidence Decay {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 11
      }
    }
    drift: Drift Detection {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 11
      }
    }
  }

  shared_memory: Shared Memory (Supabase) {
    style: {
      fill: "#e8f4f0"
      stroke: "#2d4a5e"
      border-radius: 4
      font-size: 14
    }

    score_store: score_store {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 11
      }
    }
    job_store: job_store {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 11
      }
    }
    rls: RLS (tenant isolation) {
      style: {
        fill: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 11
      }
    }
  }

  ontology -> context_graph: defines structure {
    style: {
      stroke: "#4a9e8e"
      font-size: 10
    }
  }
  context_graph -> shared_memory: persists state {
    style: {
      stroke: "#4a9e8e"
      font-size: 10
    }
  }

  # Domain pluggability
  domains: {
    style: {
      fill: transparent
      stroke: transparent
    }

    d1: Domain 1 {
      style: {
        fill: "#4a9e8e"
        font-color: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
        bold: true
      }
    }
    d2: Domain 2 {
      style: {
        fill: "#4a9e8e"
        font-color: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
        bold: true
      }
    }
    dn: Domain N {
      style: {
        fill: "#4a9e8e"
        font-color: "#ffffff"
        stroke: "#2d4a5e"
        border-radius: 4
        font-size: 12
        bold: true
      }
    }
    dots: "..." {
      style: {
        fill: transparent
        stroke: transparent
        font-size: 16
        bold: true
      }
    }
  }

  domains.d1 -> shared_memory: plugs in {
    style: {
      stroke: "#4a9e8e"
      stroke-dash: 3
      font-size: 9
    }
  }
  domains.d2 -> shared_memory: plugs in {
    style: {
      stroke: "#4a9e8e"
      stroke-dash: 3
      font-size: 9
    }
  }
  domains.dn -> shared_memory: plugs in {
    style: {
      stroke: "#4a9e8e"
      stroke-dash: 3
      font-size: 9
    }
  }

  subtitle: |md
    Domain-agnostic
    Any vertical plugs in via manifest.yaml
  | {
    style: {
      fill: transparent
      stroke: transparent
      font-size: 11
      font-color: "#6b7b8a"
    }
  }
}

# ============================================================
# INTER-PANEL CONNECTIONS
# ============================================================
agent_runtime -> orchestration: agents compose into pipelines {
  style: {
    stroke: "#2d4a5e"
    stroke-width: 2
    font-size: 11
  }
}
orchestration -> infrastructure: traces persist to shared memory {
  style: {
    stroke: "#2d4a5e"
    stroke-width: 2
    font-size: 11
  }
}
